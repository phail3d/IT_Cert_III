# make a function that does the encryption
def encrypt():  #define the function
    try:  #be graceful if there's no file present
        with open("password.txt","r") as clearText:  #open the unencrypted password file in read mode, assigning its contents to the variable 'clearText'
            charSet="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz`~!@#$%^&*()_-=|\\}]{[\"':;?/>.<, "  #define the character set in use
            encText = "".join([charSet[(charSet.find(c)+3)%94] if c in charSet else c for c in clearText.read()])   #encrypt the 'clearText' varable by rotating the character by 3 and storing this string in 'encText'
        with open("password.txt","w") as file:  #reopen password.txt in write mode
            file.write(encText)  #write the contents of encText into the file
    except FileNotFoundError:  #if password.txt doesn't exist
        pass  #just skip this function so you don't error out

#make a function that does the decryption
def decrypt():  #define the function
    try:  #be graceful if there's no file present
        with open("password.txt","r") as encText:  #open the encrypted password.txt file in read mode, assign contents to variable 'encText'
            charSet="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz`~!@#$%^&*()_-=|\\}]{[\"':;?/>.<, "  #define the character set in use
            clearText = "".join([charSet[(charSet.find(c)-3)%94] if c in charSet else c for c in encText.read()])  #decrypt the 'encText' varable by rotating the character by -3 and storing this string in 'clearText'
        with open("password.txt","w") as file:  #reopen password.txt in write mode
            file.write(clearText)  #write the contents of clearText into the file
    except FileNotFoundError:  #if password.txt doesn't exist
        pass  #just skip this function so you don't error out



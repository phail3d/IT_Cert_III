# declare some variables globally so that they can be passed between functions
clear_text = ""
enc_text = ""

# Build a Menu as a function to be able to call it whenever needed.
def display_menu():  #Define the menu function
    print("\033[H\033[2J", end="")  #clear the screen. I just googled a clear console command, this one doesn't need any libraries or OS dependencies
    print("-" * 20)  #Make a line to make it pretty
    print("Welcome to Rhys' Magic Password Storage Database Encryptomatic 5000")  #Just for lols
    print("1. Enter New Credentials")  #Menu options
    print("2. Display Password Database")  #Menu options
    print("3. Exit")  #Menu options
    print("-" * 20)  #Make a line to make it pretty

# Build the main part of the program

def main():  #define the function
    global clear_text, enc_text  #tell the function to use the global variables instead of making its own
    while True:  #while loop to keep the menu active
        display_menu()  #call the menu
        choice = input("Enter your selection (1-3): ")  #request user input, assign resulting input to a variable called 'choice'
        if choice == '1':  #if user enters '1' they want a new credential set
            print("Please enter the username you would like to use")  #request username
            username = input()  #take input and store as variable 'username'
            print("Please enter the password you would like to use")  #request password
            password = input()  #take input and store as variable 'username'
            print("Please describe what these credentials are for")  #request description
            description = input()  #take input and store as variable 'username'
            file_read()  # Call the file_read function
            decrypt()   # Call the decrypt function
            clear_text += f"description: {description} \n"  # append the user credentials to the clear_text variable
            clear_text += f"username:    {username} \n"     # add some spaces so the new creds will line up with each other
            clear_text += f"password:    {password} \n\n"   # sorta like I've done with these comments (even if it's against the style guide)
            encrypt()  # encrypt the clear_text variable
            file_write()  # write it to the file
            print("Entry Successful. Press Enter to continue")  # tell the user it's done
            input()  # pause so they can read it


        elif choice == '2':  # if the user selects option 2
            file_read()  # read the file
            decrypt()  # decrypt the file
            if clear_text == "":  # check if the file is empty
                 print("The credential database appears to be empty. Please add some credentials.")  # if it is, tell the user so
                 input()  # pause so they can read the error message
            else:  # if the file has contents
                print("-" * 20)  # just formatting to look pretty
                print(clear_text)  # print the passwords
                print("-" * 20)  # just formatting to look pretty
                print("Press Enter to continue")  # give the user the information they need to proceed
                input()  #wait for user's input

        elif choice == '3':  #if the user wants to exit
            print("Thankyou, please have a nice day")  #say something nice
            break  #end the while loop

        else:  #if the user presses a button that hasn't been defined
            print("Invalid option, please try again")  #tell them they're silly
            input()  #pause so they can read it


# make a function that does the encryption
def encrypt():  #define the function
    global clear_text, enc_text  #tell the function to use the global variables instead of making its own
    charSet="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz`~!@#$%^&*()_-=|\\}]{[\"':;?/>.<, "  #define the character set in use
    enc_text = "".join([charSet[(charSet.find(c)+3)%94] if c in charSet else c for c in clear_text])   #encrypt the 'clear_text' varable by rotating the character by 3 and storing this string in 'enc_text'


#make a function that does the decryption
def decrypt():  #define the function
    global clear_text, enc_text  #tell the function to use the global variables instead of making its own
    charSet="0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz`~!@#$%^&*()_-=|\\}]{[\"':;?/>.<, "  #define the character set in use
    clear_text = "".join([charSet[(charSet.find(c)-3)%94] if c in charSet else c for c in enc_text])  #decrypt the 'enc_text' varable by rotating the character by -3 and storing this string in 'clear_text'


# Make a function that reads the from the txt file
def file_read():  # Define the function
    global enc_text  # tell the function to use the global variable instead of making its own
    try:  #be graceful if there's no file present
        with open("password.txt","r") as pass_file:  #open the encrypted password.txt file in read mode, create a variable called 'pass_file'
             enc_text = pass_file.read()  # Read the contents of the file and assign the contents to the variable 'enc_text'
    except FileNotFoundError:  #what to do in the event of there not being a password.txt file present
        enc_text = ""  # Clear enc_text from memory


# Make a function that writes to the text file
def file_write():  # Define the function
    global enc_text  # tell the function to use the global variable instead of making its own
    with open("password.txt", "w") as pass_file:  # Open the encrypted password.txt file in write mode, create a variable called 'pass_file'
        # Use 'write' mode instead of 'append' as the input strings are appended to the variable.
        pass_file.write(enc_text)  # Write the variable to the file.

main()  #call the main function
